<?xml version='1.0' encoding='utf-8'?>
<diff>
  <replace sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='EvaluateShortages']/actions/do_if[@value='@md.FactionLogic_Economy.GlobalStorageData.$Reports']/do_if[@value='$OwnerReports']/set_value[@exact='7200'][@name='$OverflowWareThreshold']/@exact">14400</replace>
  <replace sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='EvaluateShortages']/actions/do_if[@value='@md.FactionLogic_Economy.GlobalStorageData.$Reports']/do_if[@value='$OwnerReports']/set_value[@exact='20000'][@name='$OverflowInsufficientWareThreshold']/@exact">40000</replace>
  <add sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='EvaluateShortages']/cues/cue[@name='EvaluateSectorShortage']/actions/do_if[@value='$TableRefIndex le $TableRefKeys.count']/do_all[@exact='$SubTableRefKeys.count']/do_if[@value='$IsProductionIssue'][1]" pos="before">
    <debug_text text="'FL:ECO %s: Faction: %s -- $Ware: %s -- $IsProductionIssue: %s (true = production, false = transportation) -- $CanProduceTable.{$Ware}: %s -- $SectorSellOfferValue: %s -- $SectorBuyOfferValue: %s (x0.6 = %s) -- $OverflowValue: %s'.[player.age,$Faction,$Ware,$IsProductionIssue,$CanProduceTable.{$Ware},$SectorSellOfferValue,$SectorBuyOfferValue,$SectorBuyOfferValue * 0.6f,$OverflowValue]" context="false" filter="economy_verbose" />
  </add>
  <add sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='EvaluateShortages']/cues/cue[@name='EvaluateSectorShortage']/actions/do_if[@value='$TableRefIndex le $TableRefKeys.count']/do_all[@exact='$SubTableRefKeys.count']/do_if[@value='$PursueNewAction']/do_all[@exact='$ActionThresholdsKeys.count']/do_elseif[@value='$AdjustedSectorValue ge $ActionCost']/do_if[@value='$ChosenAction']/do_elseif[6]/do_if[@value='$SectorSellOfferValue gt ($SectorBuyOfferValue * 1.2f)']" pos="before">
    <debug_text text="'FL:ECO %s: Faction: %s -- $Ware: %s -- $ChosenAction: %s -- $SectorSellOfferValue: %s -- $SectorBuyOfferValue: %s'.[player.age,$Faction,$Ware,$ChosenAction,$SectorSellOfferValue,$SectorBuyOfferValue]" context="false" filter="economy_verbose" />
  </add>
  <replace sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='Pause_Production_Module']/actions/do_else/do_if[@value='$Station']/do_if[@value='$ProductionModule']/set_production_paused[@object='$ProductionModule']/@paused">false</replace>
  <add sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='Request_Production_Module']/actions/set_value[@name='$DebugText'][@chance='$DebugChance']" pos="before">
    <do_if value="$Faction == faction.hatikvah">
      <set_value name="$CheckProductionCompatibility" exact="true" />
    </do_if>
  </add>
  <add sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='Request_Production_Module']/actions/do_else/do_elseif[@value='$Station']/do_else/do_if[@value='$ProductionMacro']">
    <do_if value="true">
      <set_value name="$DALocCount" min="1" max="2" />
      <do_all exact="$DALocCount">
        <append_to_list name="$WantedProductions" exact="$ProductionMacro" />
      </do_all>
      <remove_value name="$DALocCount" />
    </do_if>
  </add>
  <replace sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='Request_Factory']/actions/do_else[1]/do_else/do_if[@value='$Zone or @$BuildInSector']/do_if[@value='not $ProductionPlanned']/do_else/set_value[@exact='if $Ware.hastag.recycling then 3 else 1'][@name='$ProductionLimit']/@exact">if $Ware.hastag.recycling then 3 else 5</replace>
  <replace sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='Request_Factory']/actions/do_else[1]/do_else/do_if[@value='$Zone or @$BuildInSector']/do_if[@value='not $ProductionPlanned']/do_else/do_if[@value='@$BuildInSector']/create_factory[@owner='$Faction'][@sector='$RequestSector'][@race='$Faction.primaryrace'][@name='$Station']/safepos/@radius">21km</replace>
  <replace sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='Request_Factory']/actions/do_else[1]/do_else/do_if[@value='$Zone or @$BuildInSector']/do_if[@value='not $ProductionPlanned']/do_else/do_else/create_factory[@owner='$Faction'][@race='$Faction.primaryrace'][@name='$Station']/safepos[@max='40km']/@radius">21km</replace>
  <replace sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='Request_Factory']/actions/do_else[1]/do_else/do_if[@value='$Zone or @$BuildInSector']/do_if[@value='not $ProductionPlanned']/do_if[@value='$PrefabConstructionPlan']/do_if[@value='@$BuildInSector']/create_station[@name='$Station'][@owner='$Faction'][@sector='$RequestSector']/safepos/@radius">21km</replace>
  <replace sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='Request_Factory']/actions/do_else[1]/do_else/do_if[@value='$Zone or @$BuildInSector']/do_if[@value='not $ProductionPlanned']/do_if[@value='$PrefabConstructionPlan']/do_else/create_station[@name='$Station'][@owner='$Faction'][@zone='$Zone']/safepos[@max='40km']/@radius">21km</replace>
  <add sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='Remove_Factory']/actions/do_if[@value='$Station.exists']/find_object_component[@class='class.module'][@name='$StationModules'][@object='$Station']" pos="before">
    <debug_text text="'FL:ECO %s: Factory %s (%s, %s) in %s beginning evacuation to be deconstructed.'.[player.age,$Station.knownname, $Station, $Station.idcode, $Station.sector.knownname]" context="false" filter="economy_verbose" />
  </add>
  <!-- Chem: Proactively expand staged prefab stations at a lower effective threshold.
       If a staged station in this sector has a further stage available to build,
       and there is any positive production shortage score below the normal threshold,
       give a 1-in-3 random chance to boost the score up to request_production level. -->
  <add sel="/mdscript/cues/library[@name='Econ_Manager']/cues/cue[@name='EvaluateShortages']/cues/cue[@name='EvaluateSectorShortage']/actions/do_if[@value='$TableRefIndex le $TableRefKeys.count']/do_all[@exact='$SubTableRefKeys.count']/do_if[@value='$AdjustedSectorValue le 0']" pos="before">
    <!-- Chem: check for an idle staged station ready for next-stage expansion -->
    <do_if value="$IsProductionIssue and $AdjustedSectorValue gt 0 and $AdjustedSectorValue lt 14400">
      <find_station_by_true_owner name="$DAStagedStation" faction="$Faction" space="$Sector" checkoperational="false" hasfixedconstruction="false">
        <match hasstagedconstruction="true" />
        <match_child exact="0" class="class.module" state="componentstate.construction" />
      </find_station_by_true_owner>
      <do_if value="$DAStagedStation.exists">
        <!-- Chem: 1-in-3 chance to boost score to threshold and trigger early expansion -->
        <set_value name="$DAStageRoll" min="1" max="3" />
        <do_if value="$DAStageRoll == 1">
          <set_value name="$AdjustedSectorValue" exact="14400" />
          <debug_text text="'Chem: staged prefab early expansion triggered for faction ' + $Faction + ' in sector ' + $Sector.knownname + ' for ware ' + $Ware" context="false" filter="economy_verbose" />
        </do_if>
        <remove_value name="$DAStageRoll" />
      </do_if>
      <remove_value name="$DAStagedStation" />
    </do_if>
  </add>
</diff>