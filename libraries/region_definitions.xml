<?xml version='1.0' encoding='utf-8'?>
<diff>
  <!-- NOTE: All <resources>/<resource @yield> ops have been removed — they are fully inert in X4 9.00. -->
  <!-- Resource yields are now controlled exclusively via <resourceareas> in mapdefaults.xml.         -->

  <!-- Extend high-yield region radii (physical boundary, not resource yield) -->
  <replace sel="/regions/region[@name='region_highyield_ore']/boundary[@class='cylinder']/size/@r">10000</replace>
  <replace sel="/regions/region[@name='region_highyield_silicon']/boundary[@class='cylinder']/size/@r">10000</replace>
  <replace sel="/regions/region[@name='region_highyield_nividium']/boundary[@class='cylinder']/size/@r">10000</replace>

  <!-- C26 Savage Spur I — additional silicon asteroid visual density -->
  <add sel="/regions/region[@name='region_cluster_26_sector_001']/fields">
    <asteroid groupref="asteroid_silicon_m" densityfactor="3.0" noisescale="25000" seed="26021984" minnoisevalue="0.75" maxnoisevalue="1" />
  </add>
  <add sel="/regions/region[@name='region_cluster_26_sector_001']/fields">
    <asteroid groupref="asteroid_silicon_l" densityfactor="0.375" noisescale="25000" seed="26021984" minnoisevalue="0.8" maxnoisevalue="1" />
  </add>

  <!-- C33 Avarice — additional ore/silicon asteroid visual density -->
  <add sel="/regions/region[@name='region_cluster_33_sector_001']/fields">
    <asteroid groupref="asteroid_ore_l" densityfactor="0.75" noisescale="50000" seed="1309" minnoisevalue="0.65" maxnoisevalue="1" />
  </add>
  <add sel="/regions/region[@name='region_cluster_33_sector_001']/fields">
    <asteroid groupref="asteroid_silicon_l" densityfactor="0.75" noisescale="50000" seed="1309" minnoisevalue="0.65" maxnoisevalue="1" />
  </add>
  <add sel="/regions/region[@name='region_cluster_33_sector_001']/fields">
    <asteroid groupref="asteroid_ore_m" densityfactor="1.0" noisescale="50000" seed="1309" minnoisevalue="0.625" maxnoisevalue="1" />
  </add>
  <add sel="/regions/region[@name='region_cluster_33_sector_001']/fields">
    <asteroid groupref="asteroid_silicon_m" densityfactor="1.0" noisescale="50000" seed="1309" minnoisevalue="0.625" maxnoisevalue="1" />
  </add>

  <!-- C36 Windfall — set nebula visual resources (methane/hydrogen/helium atmosphere) -->
  <replace sel="/regions/region[@name='region_cluster_36_sector_001']/fields/nebula[@ref='fogpattern_v2_macro']/@resources">methane hydrogen helium</replace>
</diff>